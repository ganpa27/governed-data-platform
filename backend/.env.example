# ─────────────────────────────────────────────────
#  Governed Data Platform – Environment Variables
#  Copy this file to .env and fill in real values.
# ─────────────────────────────────────────────────

# Databricks connection
DATABRICKS_SERVER_HOSTNAME=<your-workspace>.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_TOKEN=<your-personal-access-token>

# Catalog / Schema
DATABRICKS_CATALOG=governed_platform_catalog
DATABRICKS_SCHEMA=finance_schema

# Application
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── Stage 3: AI Orchestration ─────────────────────────────────────────────────
# Provider: mock (safe default) | kimi | openai | azure
#   mock   – returns hardcoded safe SQL; no API cost; use in development / CI
#   kimi   – Kimi (Moonshot AI); OpenAI-compatible; fast & cost-effective
#   openai – requires OPENAI_API_KEY; calls ChatGPT
#   azure  – placeholder, not yet implemented
LLM_PROVIDER=kimi

# ── Kimi (Moonshot AI) ─────────────────────────────────────────────────────────
# Get your API key from: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=sk-...
# Available models:
#   moonshot-v1-8k    → fast, lowest cost, best for SQL generation (recommended)
#   moonshot-v1-32k   → larger context window
#   moonshot-v1-128k  → maximum context (overkill for SQL gen)
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.ai/v1   # rarely needs changing

# ── OpenAI (alternative) ───────────────────────────────────────────────────────
# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Shared AI settings ────────────────────────────────────────────────────────
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.1           # Low = deterministic SQL output

# Per-role row caps enforced by LIMIT injector (overridable via env)
# These prevent bulk data exfiltration regardless of LLM behaviour.
# ROLE_ROW_LIMITS={"admin": 1000, "finance_user": 500, "auditor": 200}
# DEFAULT_ROW_LIMIT=100
